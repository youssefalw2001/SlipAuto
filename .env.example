# YOINK.GG Environment Variables
# Copy this file to .env and fill in your values

# Supabase — get from supabase.com → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Solana — Arena Pool ──────────────────────────────────────────────────────
# Network: mainnet-beta | devnet | testnet
VITE_SOLANA_NETWORK=mainnet-beta

# Optional: custom RPC (Helius, QuickNode etc — faster than default)
# VITE_SOLANA_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Pool wallet — the Solana address that holds the arena pool funds
# Create a new wallet with `solana-keygen new` and put the PUBLIC key here
VITE_POOL_WALLET=YOUR_POOL_WALLET_PUBLIC_KEY

# Rake wallet — your revenue wallet (10% of every entry goes here instantly)
# Can be your personal Phantom wallet address
VITE_RAKE_WALLET=YOUR_RAKE_WALLET_PUBLIC_KEY
